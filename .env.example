ADMIN_PASSWORD=change-me
HU_ADMIN_PASSWORD=change-me-hu
ADMIN_SESSION_SECRET=change-me-too
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# URL public al site-ului (Stripe, SEO: canonical, Open Graph, sitemap.xml, robots.txt)
# Folositi exact domena finala (cu sau fara www), aceeasi ca in Google Search Console.
NEXT_PUBLIC_SITE_URL=https://www.cumparatisenzor.ro

# Google Analytics 4 — ID de tip G-XXXXXXXXXX (vezi instructiunile in raspunsul asistentului)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Stripe — plata cu cardul (Checkout). Obtineti cheile din Stripe Dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public — optional pentru viitoare componente (Elements); Checkout functioneaza doar cu secret pe server.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Link-uri retele sociale (pana sunt gata paginile, puteti lasa necompletat = link # in footer)
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_META_URL=

# SMTP config for real e-mail sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@cumparatisenzor.ro
SMTP_FROM_HU=info@szenzorvasarlas.hu

# Copie comanda noua catre echipa (optional)
INTERNAL_ORDER_EMAIL=info@cumparatisenzor.ro
INTERNAL_ORDER_EMAIL_RO=info@cumparatisenzor.ro
INTERNAL_ORDER_EMAIL_HU=info@szenzorvasarlas.hu

# Optional PPL API integration (auto-create shipment after paid -> ready for shipping)
PPL_API_ENABLED=false
PPL_API_BASE_URL=
PPL_API_TOKEN=
PPL_API_TOKEN_URL=
PPL_API_CLIENT_ID=
PPL_API_CLIENT_SECRET=
PPL_API_SCOPE=myapi2
PPL_API_USERNAME=
PPL_API_PASSWORD=
PPL_API_CREATE_SHIPMENT_PATH=/shipment/batch
PPL_API_POLL_PATH=/shipment/batch
PPL_API_MAX_POLLS=12
PPL_API_POLL_DELAY_MS=1500
PPL_API_ACCEPT_LANGUAGE=cs-CZ
PPL_PRODUCT_TYPE=BUSS
PPL_PRODUCT_TYPE_INTL=CONN
PPL_PRODUCT_TYPE_RO=CONN
PPL_PRODUCT_TYPE_HU=CONN
# COD shipments use a COD-capable product (default COND). Override if PPL activated another type.
# PPL_PRODUCT_TYPE_COD_HU=COND
# PPL_PRODUCT_TYPE_COD_INTL=
PPL_DEPOT=
PPL_SERVICES=
PPL_LABEL_DPI=300
# CPL API enum ConstPageSize: only Default or A4 (A6 is not supported by PPL; use Default ≈ 150×100 mm).
PPL_LABEL_PAGE_SIZE=Default
PPL_LABEL_POSITION=1
PPL_LABEL_EMAIL=
PPL_LABEL_EMAIL_RO=
PPL_LABEL_EMAIL_HU=
PPL_SENDER_NAME=
PPL_SENDER_STREET=
PPL_SENDER_CITY=
PPL_SENDER_ZIP=
# ISO 3166-1 alpha-2 (CZ, SK, …). Not “Czech Republic” — or use that phrase; app maps common names to CZ.
PPL_SENDER_COUNTRY=CZ
PPL_SENDER_PHONE=
PPL_SENDER_EMAIL=
PPL_COD_IBAN=
PPL_COD_SWIFT=
# COD settlement currency defaults to local shop currency (HU=HUF, RO=RON).
# If your PPL contract requires another currency, set it explicitly here (e.g. CZK or EUR).
# PPL_COD_CURRENCY_HU=HUF
# How many HUF = 1 CZK (e.g. 5.2). Required only when settlement is CZK and order total is in HUF.
# PPL_COD_HUF_PER_CZK=5.2
# Other settlement currency: set PPL_COD_CURRENCY_HU=EUR and PPL_COD_FX_MULTIPLIER (HUF * mult = amount in EUR).
# PPL_COD_CURRENCY_RO=RON

# Optional DPD Shipping API integration
DPD_API_ENABLED=false
DPD_API_BASE_URL=https://shipping.dpdgroup.com/api
DPD_API_TOKEN=
DPD_API_CUSTOMER_ID=
DPD_API_SENDER_ADDRESS_ID=
DPD_API_BU_CODE=015
DPD_API_CREATE_SHIPMENT_PATH=/v1.1/shipments
DPD_API_LABEL_PATH=/v1.0/label/shipment-ids
DPD_API_LABEL_SIZE=A6
DPD_API_SAVE_MODE=final
DPD_API_COD_PAYMENT_TYPE=Cash
DPD_API_DEFAULT_WEIGHT_KG=1

# Afisate pe pagina de plata (transfer bancar)
BANK_ACCOUNT_NAME=Česká maloobchodní s.r.o.
BANK_IBAN=
BANK_NAME=
BANK_BIC=
BANK_PAYMENT_NOTE=Mentionati numarul comenzii in referinta platii.
